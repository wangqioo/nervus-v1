# Caddyfile — Nervus 反向代理

{
    local_certs
    default_sni nervus.local
    log {
        level INFO
    }
}

# ── 主域名入口 ──────────────────────────────────
nervus.local, https://150.158.146.192 {

    # ── Per-app API routes (must be before /api/* catch-all) ──
    handle /api/model-manager/* {
        uri strip_prefix /api/model-manager
        reverse_proxy nervus-app-model-manager:8016
    }
    handle /api/file-manager/* {
        uri strip_prefix /api/file-manager
        reverse_proxy nervus-app-files:8015
    }
    handle /api/files* {
        reverse_proxy nervus-app-files:8015
    }
    handle /api/image-proxy* {
        reverse_proxy nervus-app-files:8015
    }
    handle /api/llm/* {
        uri strip_prefix /api/llm
        reverse_proxy nervus-llama:8080
    }
    handle /api/calorie/* {
        uri strip_prefix /api/calorie
        reverse_proxy nervus-app-calorie:8001
    }
    handle /api/meeting/* {
        uri strip_prefix /api/meeting
        reverse_proxy nervus-app-meeting:8002
    }
    handle /api/knowledge/* {
        uri strip_prefix /api/knowledge
        reverse_proxy nervus-app-knowledge:8003
    }
    handle /api/life/* {
        uri strip_prefix /api/life
        reverse_proxy nervus-app-life:8004
    }
    handle /api/sense/* {
        uri strip_prefix /api/sense
        reverse_proxy nervus-app-sense:8005
    }
    handle /api/photo/* {
        uri strip_prefix /api/photo
        reverse_proxy nervus-app-photo:8006
    }
    handle /api/notes/* {
        uri strip_prefix /api/notes
        reverse_proxy nervus-app-notes:8007
    }
    handle /api/pdf/* {
        uri strip_prefix /api/pdf
        reverse_proxy nervus-app-pdf:8008
    }
    handle /api/video/* {
        uri strip_prefix /api/video
        reverse_proxy nervus-app-video:8009
    }
    handle /api/rss/* {
        uri strip_prefix /api/rss
        reverse_proxy nervus-app-rss:8010
    }
    handle /api/calendar/* {
        uri strip_prefix /api/calendar
        reverse_proxy nervus-app-calendar:8011
    }
    handle /api/reminder/* {
        uri strip_prefix /api/reminder
        reverse_proxy nervus-app-reminder:8012
    }
    handle /api/status-sense/* {
        uri strip_prefix /api/status-sense
        reverse_proxy nervus-app-status-sense:8013
    }
    handle /api/workflow/* {
        uri strip_prefix /api/workflow
        reverse_proxy nervus-app-workflow:8014
    }
    # ── Arbor Core (catch-all for /api/*) ──
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy nervus-arbor:8090
    }

    # WebSocket
    handle /ws/* {
        reverse_proxy nervus-arbor:8090 {
            header_up Upgrade {http.upgrade}
            header_up Connection "Upgrade"
        }
    }

    # Static frontend
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}

