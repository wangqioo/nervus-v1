# Nervus 环境变量配置示例
# 复制为 .env 并填入真实值，docker-compose 会自动加载

# ── 基础设施 ─────────────────────────────────────────────────
POSTGRES_URL=postgresql://nervus:nervus_secret@postgres:5432/nervus
REDIS_URL=redis://redis:6379
NATS_URL=nats://nats:4222
ARBOR_URL=http://arbor:8090

# ── 云端模型 API Keys ────────────────────────────────────────
# 填入后对应模型自动上线，留空则该模型离线

# DeepSeek（推荐，性价比高）
DEEPSEEK_API_KEY=

# Anthropic（Claude 系列）
ANTHROPIC_API_KEY=

# 智谱 AI（GLM 系列）
ZHIPUAI_API_KEY=

# 阿里云通义千问
DASHSCOPE_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Groq（极速推理）
GROQ_API_KEY=
